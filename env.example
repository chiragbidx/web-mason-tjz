# OpenAI defaults
OPENAI_API_KEY=your-openai-api-key
# Optional; falls back to this model when unset in runtime code
OPENAI_MODEL=gpt-4o-mini

# Database (PostgreSQL on Railway example)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL="postgresql://postgres:password@hostname:5432/railway"
DATABASE_SSL=false

# Canonical app URL for NextAuth; prefer over NEXTAUTH_URL
BASE_URL="http://localhost:3000"

# Auth.js / NextAuth secret (use the AUTH_SECRET already present in deployment envs)
NEXTAUTH_SECRET=${AUTH_SECRET}
